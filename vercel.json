{
  "framework": "nextjs",
  "installCommand": "npm install",
  "buildCommand": "npm run build",
  "regions": ["cdg1"],
  "crons": [
    {
      "path": "/api/cron/smart-alerts",
      "schedule": "15 6 * * *"
    },
    {
      "path": "/api/cron/alert-notifications",
      "schedule": "30 6 * * *"
    },
    {
      "path": "/api/cron/sale-change-monitor",
      "schedule": "45 6 * * *"
    },
    {
      "path": "/api/cron/precompute-valuations",
      "schedule": "30 5 * * *"
    }
  ]
}

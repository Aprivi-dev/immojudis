VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=your-publishable-anon-key
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=your-publishable-anon-key

# Mapbox powers interactive maps and static listing thumbnails.
# Example style: mapbox/streets-v12 or mapbox://styles/<user>/<style>
NEXT_PUBLIC_MAPBOX_ACCESS_TOKEN=
NEXT_PUBLIC_MAPBOX_STYLE=mapbox/streets-v12

# Optional legacy fallback: custom OpenStreetMap-compatible tile template.
NEXT_PUBLIC_OSM_TILE_URL=

# Server-side variables used only by trusted server routes/middleware.
# Do not expose SUPABASE_SECRET_KEY or SUPABASE_SERVICE_ROLE_KEY in browser code.
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_PUBLISHABLE_KEY=your-publishable-anon-key
SUPABASE_SECRET_KEY=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_DB_URL=
POSTGRES_URL_NON_POOLING=
POSTGRES_URL=

# Optional: Stripe Billing for the Analyse subscription.
# Configure these in Vercel/server envs before activating paid checkout.
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_ANALYSE_PRICE_ID=
STRIPE_INVESTISSEUR_PRICE_ID=
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Optional: Vercel Cron security and smart-alert batch sizing.
# Vercel sends Authorization: Bearer $CRON_SECRET to configured cron routes.
CRON_SECRET=
SMART_ALERT_CRON_USER_LIMIT=25
SMART_ALERT_CRON_SALE_LIMIT=160
ALERT_NOTIFICATION_CRON_LIMIT=200
SALE_CHANGE_CRON_USER_LIMIT=25

# Optional: Resend transactional email delivery for smart alerts and lawyer referrals.
RESEND_API_KEY=
ALERT_EMAIL_FROM="ImmoJudis <alertes@immojudis.fr>"

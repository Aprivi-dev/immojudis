{
  "name": "immojudis",
  "description": "Plateforme d'exploration des ventes immobilières aux enchères judiciaires (Nouvelle-Aquitaine) : assistant de mise plafond, cartographie OpenStreetMap et pipeline de données.",
  "private": true,
  "sideEffects": false,
  "type": "module",
  "packageManager": "npm@10.1.0",
  "scripts": {
    "dev": "next dev",
    "dev:ready": "node scripts/dev-ready.mjs",
    "build": "node scripts/verify-required-env.mjs && node scripts/apply-supabase-migrations.mjs --if-enabled && next build",
    "build:dev": "next build",
    "start": "next start",
    "preview": "next start",
    "test": "vitest run",
    "lint": "eslint .",
    "audit:ai-descriptions": "node scripts/audit-ai-descriptions.mjs",
    "env:check:prod": "node scripts/verify-production-env.mjs",
    "db:migrate": "node scripts/apply-supabase-migrations.mjs",
    "format": "prettier --write ."
  },
  "dependencies": {
    "@radix-ui/react-alert-dialog": "^1.1.15",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-popover": "^1.1.15",
    "@radix-ui/react-slot": "^1.2.4",
    "@supabase/supabase-js": "^2.105.4",
    "@tailwindcss/postcss": "^4.3.2",
    "@tanstack/react-query": "^5.83.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "framer-motion": "^12.42.2",
    "lucide-react": "^0.575.0",
    "next": "^16.2.9",
    "postgres": "^3.4.9",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "sonner": "^2.0.7",
    "stripe": "^22.3.0",
    "tailwind-merge": "^3.5.0",
    "tailwindcss": "^4.2.1",
    "tw-animate-css": "^1.3.4",
    "zod": "^3.24.2"
  },
  "overrides": {
    "esbuild": "0.28.1",
    "postcss": "8.5.15"
  },
  "devDependencies": {
    "@eslint/js": "^9.32.0",
    "@types/node": "^22.16.5",
    "@types/react": "^19.2.0",
    "@types/react-dom": "^19.2.0",
    "eslint": "^9.32.0",
    "eslint-config-prettier": "^10.1.1",
    "eslint-plugin-prettier": "^5.2.6",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-react-refresh": "^0.4.20",
    "globals": "^15.15.0",
    "prettier": "^3.7.3",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.56.1",
    "vite": "^7.3.1",
    "vitest": "^4.1.9"
  }
}
